app.get('/api/events', async (req, res) => {
  try {
    const page = parseInt(req.query.page) || null; 
    const limit = parseInt(req.query.limit) || null; 

    if (!page && !limit) {
      // No pagination params: Return all events (for index page)
      const result = await pool.query(
        `SELECT * FROM articles WHERE published = TRUE ORDER BY post_date DESC`
      );
      res.json({
        rows: result.rows,
        total: result.rows.length,
        page: 1,
        limit: result.rows.length,
        totalPages: 1
      });
    } else {
      const actualPage = page || 1;
      const actualLimit = limit || 3;
      const offset = (actualPage - 1) * actualLimit;

      const eventsQuery = `SELECT * FROM articles WHERE published = TRUE ORDER BY post_date DESC LIMIT $1 OFFSET $2`;
      const countQuery = `SELECT COUNT(*) FROM articles WHERE published = TRUE`;

      const [events, count] = await Promise.all([
        pool.query(eventsQuery, [actualLimit, offset]),
        pool.query(countQuery)
      ]);

      const total = parseInt(count.rows[0].count);
      res.json({
        rows: events.rows,
        total,
        page: actualPage,
        limit: actualLimit,
        totalPages: Math.ceil(total / actualLimit)
      });
    }
  } catch (err) {
    console.error("Database Error:", err.message);
    res.status(500).json({ error: "Database error" });
  }
});

