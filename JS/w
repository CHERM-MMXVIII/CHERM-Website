/* ---------- FACEBOOK POST ID EXTRACTOR ---------- */
function extractFbPostId(url) {

  // Format 1: /posts/{id}
  let match = url.match(/\/posts\/([^\/\?]+)/);
  if (match) return match[1];

  // Format 2: story.php?story_fbid={id}
  match = url.match(/story_fbid=([^&]+)/);
  if (match) return match[1];

  // Format 3: pfbid... (RSS format)
  match = url.match(/(pfbid[^\/\?]+)/);
  if (match) return match[1];

  // ✅ NEW Format 4: /share/p/{shortcode}
  match = url.match(/\/share\/p\/([^\/\?]+)/);
  if (match) return match[1];

  return null;
}


/* ---------- RSS IMPORT FUNCTION (OPTIONAL AUTO IMPORT) ---------- */
async function importRSS() {
  try {
    const parser = new Parser();
    const feed = await parser.parseURL('https://rss.app/feeds/prVwaD4E2lxxoong.xml');

    for (const item of feed.items) {

      const fb_post_id = extractFbPostId(item.link);
      if (!fb_post_id) continue;

      let imageUrl = null;
      if (item['media:content']?.url) {
        imageUrl = item['media:content'].url;
      } else {
        const match = item.content?.match(/<img[^>]+src="([^">]+)"/);
        if (match) imageUrl = match[1];
      }

      await pool.query(
        `INSERT INTO articles (fb_post_id, title, image_url, post_date, fb_link, published)
        VALUES ($1, $2, $3, $4, $5, FALSE)
        ON CONFLICT (fb_post_id) DO NOTHING`,
        [
          fb_post_id,
          item.title,
          imageUrl,
          item.pubDate,
          item.link
        ]
      );


    }

    console.log("✅ RSS Import Completed");

  } catch (err) {
    console.error("❌ RSS Import Error:", err.message);
  }
}

