app.post('/admin/add', upload.single('image_file'), async (req, res) => {
  try {
    const { title, post_date, fb_link } = req.body;

    let final_title = title;
    let final_fb_link = fb_link || null;
    let image_url = null;

    /* Case 1: Manual image upload */
    if (req.file) {
      image_url = '/uploads/' + req.file.filename;
    }

    /* Case 2: Facebook link provided */
    if (fb_link && fb_link.trim() !== '') {

      const inputPostId = extractFbPostId(fb_link.trim());
      if (!inputPostId) {
        return res.send("❌ Invalid Facebook post link.");
      }

      const parser = new Parser();
      const feed = await parser.parseURL('https://rss.app/feeds/prVwaD4E2lxxoong.xml');

      const matchedItem = feed.items.find(item =>
        extractFbPostId(item.link) === inputPostId
      );

      if (!matchedItem) {
        return res.send("❌ Facebook post not found in RSS feed.");
      }

      if (!final_title || final_title.trim() === '') {
        final_title = matchedItem.title;
      }

      if (!image_url) {
        if (matchedItem['media:content']?.url) {
          image_url = matchedItem['media:content'].url;
        } else {
          const match = matchedItem.content?.match(/<img[^>]+src="([^">]+)"/);
          if (match) image_url = match[1];
        }
      }

      final_fb_link = matchedItem.link;
    }

    /* Validation */
    if (!final_title || !image_url || !post_date) {
      return res.send("❌ Title, Date, and Image are required.");
    }

    /* Insert into DB */
    await pool.query(
      `INSERT INTO articles (fb_post_id, title, image_url, post_date, fb_link, published)
      VALUES ($1, $2, $3, $4, $5, TRUE)`,
      [
        extractFbPostId(final_fb_link || '') || ('manual_' + Date.now()),
        final_title,
        image_url,
        post_date,
        final_fb_link
      ]
    );


    console.log("✅ Post successfully added by Admin");
    res.redirect('/admin');

  } catch (err) {
    console.error("Admin Insert Error:", err.message);
    res.send("Insert error: " + err.message);
  }
});

